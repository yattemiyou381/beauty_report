name: Market Intelligence Notion Direct

on:
  push:
    branches: [ main ]
  workflow_dispatch:
    inputs:
      mode:
        description: '実行モードを選択 (collect: 記事収集 / export: 承認済み出力)'
        required: true
        default: 'collect'
        type: choice
        options:
          - collect
          - export

jobs:
  run-task:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout code
        uses: actions/checkout@v4

      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: '3.10'

      - name: Install dependencies
        run: |
          python -m pip install --upgrade pip
          pip install feedparser pydantic openai notion-client

      - name: Execute Script
        env:
          OPENAI_API_KEY: ${{ secrets.OPENAI_API_KEY }}
          NOTION_TOKEN: ${{ secrets.NOTION_TOKEN }}
          NOTION_DATABASE_ID: ${{ secrets.NOTION_DATABASE_ID }}
        run: |
          if [ "${{ github.event.inputs.mode }}" == "collect" ]; then
            python main.py
          else
            python generate_final_report.py
          fi

      - name: Upload Exported Report
        if: github.event.inputs.mode == 'export'
        uses: actions/upload-artifact@v4
        with:
          name: Final-Blog-Report
          path: Final_Report_*.md
